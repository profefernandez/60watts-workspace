# 60 Watts of Clarity — Environment Variables
# Copy this to .env.local and fill in values

# Anthropic Claude API Key (required for Profé AI)
ANTHROPIC_API_KEY=

# Model selection (default: claude-sonnet-4-20250514)
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# App URL (for CORS / redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Future: Database
# DATABASE_URL=postgresql://user:pass@localhost:5432/sixty_watts

# Future: S3-compatible storage
# S3_ENDPOINT=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_BUCKET=
